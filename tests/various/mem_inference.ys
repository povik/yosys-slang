design -reset
test_slangdiag -expect "cannot infer memory from a variable despite 'ram_block' attribute"
read_slang <<EOF
module top(
	input clk,
	input rst,
	input [1:0] a,
	input [7:0] data,
	output reg [7:0] q
);
	(* ram_block *)
	reg [7:0] x[0:3];

	always @(posedge clk or posedge rst) begin
		if (rst)
			x <= '{default:8'h00};
		else begin
			q <= x[a];
			x[a] <= data;
		end
	end
endmodule
EOF
