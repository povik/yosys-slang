# Read with comments and also swap left/right bounds
design -reset
read_slang --no-implicit-memories <<EOF
module top5(input [1:0] addr);
	(* rom_block *)
	reg [7:0] x[3:0];
	reg [7:0] y[3:0];

	initial begin
		$readmemh("readmem_comments.hex", x);
		y = '{8'h04, 8'h03, 8'h02, 8'h01};
	end

	wire [7:0] lhs = x[addr];
	wire [7:0] rhs = y[addr];

	always_comb
		if (^addr !== 'x)
			assert(lhs === rhs);
endmodule
EOF
chformal -lower
memory_collect
memory_map
sat -verify -enable_undef -prove-asserts -show-all

