design -reset
read_slang --no-implicit-memories <<EOF
module top();
	(* rom_block *)
	reg [3:0] x[1:0];
	reg [3:0] y[1:0];

	initial begin
		x = '{7, 1};
		y = '{7, 1};
	end

	always_comb
		assert(x[0] === y[0] && x[1] === y[1]);
endmodule
EOF

chformal -lower
memory_collect
select -assert-count 1 t:$mem_v2
memory_map
sat -verify -enable_undef -prove-asserts

