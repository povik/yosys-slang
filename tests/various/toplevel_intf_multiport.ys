read_slang --allow-toplevel-iface-ports <<EOF
interface bus();
	logic a;
	modport src(output a);
	modport dst(input a);
endinterface

module top(bus.src s0, bus.src s1, bus.dst d);
	always_comb begin
		if (d.a) begin
			s0.a = 1'b1;
			s1.a = 1'b0;
		end else begin
			s0.a = 1'b0;
			s1.a = 1'b1;
		end
	end
endmodule
EOF
select -assert-count 1 w:s0.a
select -assert-count 1 w:s1.a
select -assert-count 1 w:d.a
