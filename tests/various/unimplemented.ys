logger -expect error ".*Feature unimplemented.*" 1
read_slang <<EOF
// See IEEE 1800-2017 p. 19.7.1.
module covergroup_unsupported(input clk);
   int a_var, b_var;

   covergroup gc @(posedge clk);
      a : coverpoint a_var;
      b : coverpoint b_var;
   endgroup

   initial
      // Set the comment for all covergroups of type "gc"
      gc::type_option.comment = "Here is a comment for covergroup g1";

   initial
      // Set the weight for covergroup "a" of all covergroups of type gc
      gc::a::type_option.weight = 3;

   gc g1 = new;
endmodule
EOF
